# openautolink.env — Configuration for OpenAutoLink bridge
# Place in /etc/openautolink.env or /boot/firmware/openautolink.env

# ── Car Network Mode ──────────────────────────────────────────────────
# How the bridge connects to the car's head unit:
#   external-nic — Onboard eth0 connects to car via USB Ethernet adapter.
#                  This is the tested and supported mode.
#   auto         — (Experimental) Try USB gadget first, fall back to eth0.
#   usb-gadget   — (Experimental) Force USB gadget only.
OAL_CAR_NET_MODE=external-nic

# USB gadget protocol for car communication:
#   rndis   — RNDIS (most compatible with Android/Windows hosts, recommended)
#   ecm     — CDC-ECM (standard Linux ethernet-over-USB, less compatible)
#   ncm     — CDC-NCM (newer, better performance, requires kernel support)
OAL_CAR_NET_PROTO=rndis

# Seconds to wait for USB gadget carrier (car detecting the device).
# Only used in 'auto' mode. If carrier doesn't come up, falls back to eth0.
OAL_CAR_NET_GADGET_TIMEOUT=10

# Include mass_storage (UDisk) in USB gadget composite device.
# Required for GM EVs to avoid "unsupported device" popup.
# Set to 0 if your car doesn't need it.
OAL_CAR_NET_UDISK=1

# ── Car App Transport ─────────────────────────────────────────────────
# TCP port the bridge listens on for the car's app connection.
# OAL protocol: control=5288, audio=5289, video=5290 (port, port+1, port+2)
OAL_CAR_TCP_PORT=5288

# Static IP for the bridge's car-facing NIC.
# Set on eth0 (onboard NIC connected to car via USB Ethernet adapter).
# The car app connects to this IP.
OAL_CAR_NET_IP=192.168.222.222
OAL_CAR_NET_MASK=24

# ── SSH/Management Network ────────────────────────────────────────────
# The NIC not used for car gets SSH access. Mode:
#   dhcp-client (default) — get IP from whatever provides DHCP
#     Works with laptop WiFi sharing (ICS), routers, etc.
#   static — set a fixed IP, no DHCP client or server
#     Use with laptop ICS when you want a known IP on the bridge.
#   dhcp-server — run DHCP server on the SSH NIC for direct connections
#     Use when connecting a laptop directly without any DHCP source.
OAL_SSH_MODE=static
OAL_SSH_IP=192.168.137.2
OAL_SSH_DHCP_START=10.0.0.10
OAL_SSH_DHCP_END=10.0.0.50

# ── Bridge Update Mode ────────────────────────────────────────────────
# Controls whether the bridge accepts OTA updates pushed from the car app.
#   auto     — Accept updates from app (default for end users)
#   disabled — Reject all update offers (for developers building locally via WSL/SSH)
# When switching from disabled back to auto, the app will detect the SHA-256
# mismatch against the latest GitHub Release and push the official binary.
OAL_BRIDGE_UPDATE_MODE=auto

# ── Phone Connection Mode ─────────────────────────────────────────────
# How the phone connects to the bridge:
#   wireless  — Phone connects via WiFi (needs WiFi module on SBC)
#   usb       — Phone plugs into SBC USB host port (wired Android Auto)
# Wired mode is useful for SBCs without WiFi (e.g., ROCK 3A without WiFi module).
OAL_PHONE_MODE=wireless

# Phone protocol — which phone type the bridge accepts:
#   android-auto — Android phone via aasdk (default)
OAL_PHONE_PROTOCOL=android-auto

# TCP port for phone's Android Auto connection (wireless mode only).
OAL_PHONE_TCP_PORT=5277

# ── Wireless Android Auto ────────────────────────────────────────────
OAL_WIRELESS_ENABLE=1
# WiFi interface name (empty = auto-detect: checks wlan0, wlp*, etc.)
# Set explicitly only if auto-detection picks the wrong interface.
OAL_WIRELESS_INTERFACE=
# Band preference: 5ghz (preferred, auto-probes channels) or 24ghz (fallback)
# The script probes hardware capabilities and picks the best available config.
# 5GHz gives lower latency; falls back to 2.4GHz if hardware doesn't support it.
OAL_WIRELESS_BAND=5ghz
# Override channel (empty = auto-select best DFS-free channel for the band)
# For 5GHz: 36, 40, 44, 48, 149, 153, 157, 161 (DFS-free)
# For 2.4GHz: 1, 6, 11
OAL_WIRELESS_CHANNEL=
# Country code for regulatory domain (affects available channels)
OAL_WIRELESS_COUNTRY=US
# SSID/password — auto-generated from MAC if empty
OAL_WIRELESS_SSID=
OAL_WIRELESS_PASSWORD=
OAL_WIRELESS_RFCOMM_CHANNEL=8

# ── App Display Resolution ────────────────────────────────────────────
# These control how the app renders on the car's infotainment screen.
# Set to match your car's physical display resolution.
OAL_VIDEO_WIDTH=2400
OAL_VIDEO_HEIGHT=960

# ── Android Auto Stream Settings ─────────────────────────────────────
# These control what the PHONE sends to the bridge (encoded video stream).
# Completely separate from the app display resolution above.
#
# AA Display Density (DPI) — controls how AA lays out its UI:
#   The phone calculates: dp_width = pixels / (dpi / 160)
#   Lower DPI = more content visible, smaller controls
#   Higher DPI = bigger controls, less content visible
#
#   100 = Ultra-wide layout, max content, tiny controls
#   140 = Wide layout, more content
#   160 = Standard balanced layout (default, recommended)
#   200 = Compact layout, larger controls
#   240 = Large/phone-like layout, biggest controls
OAL_AA_DPI=160

# AA Resolution Tier — what resolution the phone encodes at:
#   480p  = 800x480   (lowest quality, lowest bandwidth)
#   720p  = 1280x720  (good balance)
#   1080p = 1920x1080 (highest confirmed working)
#   1440p = 2560x1440 (in AA proto spec but UNTESTED — phone may ignore)
#   4k    = 3840x2160 (in AA proto spec but UNTESTED — phone may ignore)
# WARNING: Resolutions above 1080p have never been confirmed working.
#          The phone typically caps at 1080p regardless of what you request.
OAL_AA_RESOLUTION=1080p

# AA Display Safe-Area Insets
#
# These tell the phone which areas of the video frame are safe for interactive
# content (buttons, cards, text) vs. background content (maps, album art).
# The phone still renders the full video frame — insets only affect where UI
# elements are placed within that frame.
#
# Two types of insets (format: top,bottom,left,right in video-coordinate pixels):
#
#   CONTENT insets  — "don't render anything here" (maps stop, black gap)
#   STABLE insets   — "render background content (maps) here, but keep
#                      interactive UI (buttons, cards, text) in the safe area"
#
# NOTE: Stable insets are now AUTO-COMPUTED from the AAOS display cutout
# reported by the app. Leave blank unless you need to override the auto values.
# The app sends display cutout insets in the hello message, and the bridge
# merges them (max of auto-computed vs configured value per edge).
OAL_AA_INIT_STABLE_INSETS=
#
# Content insets (use only if you need a hard cutoff, not just safe area):
OAL_AA_INIT_CONTENT_INSETS=
#
# Advanced video layout knobs (leave blank for auto-computation from display):
#
# These are AUTO-COMPUTED from display dimensions reported by the AAOS app:
#   - pixel_aspect_ratio: computed from display AR vs video AR
#   - height_margin: computed from vertical crop amount
#   - stable_insets: computed from AAOS display cutout
# Set a value here to OVERRIDE the auto-computation.
OAL_AA_WIDTH_MARGIN=
OAL_AA_HEIGHT_MARGIN=
OAL_AA_PIXEL_ASPECT_E4=
OAL_AA_REAL_DENSITY=
OAL_AA_VIEWING_DISTANCE=
OAL_AA_DECODER_ADDITIONAL_DEPTH=
OAL_AA_INIT_MARGINS=
# Runtime insets — sent after video stream starts (use for delayed adjustments):
OAL_AA_RUNTIME_DELAY_MS=
OAL_AA_RUNTIME_MARGINS=
OAL_AA_RUNTIME_CONTENT_INSETS=
OAL_AA_RUNTIME_STABLE_INSETS=

# AA Frame Rate — what FPS the phone encodes at:
#   30 or 60. Most phones support 60fps at 1080p.
OAL_AA_FPS=60

# AA Video Codec — what codec the phone uses to encode:
#   h264  = H.264 Baseline Profile (universal, recommended)
#   h265  = H.265/HEVC (better compression, less tested)
#   vp9   = VP9 (Google codec, less tested)
# WARNING: H.265 and VP9 support varies by phone. H.264 is safest.
OAL_AA_CODEC=h264

# ── Head Unit Identity ────────────────────────────────────────────────
OAL_HEAD_UNIT_NAME=OpenAutoLink

# ── Vehicle Identity (auto-populated from app VHAL on first connect) ──
# These are persisted by the bridge when the app sends vehicle_data.
# On first boot (before app connects), defaults are used.
# After first app connection, the real car identity is stored here.
OAL_CAR_MAKE=OpenAutoLink
OAL_CAR_MODEL=Universal
OAL_CAR_YEAR=2024

# ── AA UI Flags ───────────────────────────────────────────────────────
# Hide elements from the AA status bar (AAOS has its own UI for these)
OAL_AA_HIDE_CLOCK=true
OAL_AA_HIDE_PHONE_SIGNAL=false
OAL_AA_HIDE_BATTERY=false

# ── Bluetooth ─────────────────────────────────────────────────────────
# BT MAC address sent to phone for auto-pairing via Android Auto.
# Leave empty for auto-detection (tries sysfs, hciconfig, bluetoothctl).
# Set manually if auto-detect fails on your SBC.
# Format: XX:XX:XX:XX:XX:XX (uppercase, colon-separated)
OAL_BT_MAC=

# ── mDNS Discovery ───────────────────────────────────────────────────
# The bridge advertises _openautolink._tcp via Avahi for automatic
# discovery by the car's app.
OAL_MDNS_ENABLE=1

# ── Debug ─────────────────────────────────────────────────────────────
OAL_LOGFILE=/var/log/openautolink.log
